# ── Groq (gratis) ─────────────────────────────────────────
# Crear cuenta en https://console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_tu_api_key_aqui

# ── Meta - WhatsApp (testing gratis) ──────────────────────
# Crear app en https://developers.facebook.com → Business
# WhatsApp → Getting Started → copiar Phone ID y Token temporal
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_ACCESS_TOKEN=EAAx...
META_VERIFY_TOKEN=alm_webhook_2024_secure  # inventalo vos

# ── Meta - Instagram (opcional) ───────────────────────────
INSTAGRAM_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ── Meta - Facebook Messenger (opcional) ──────────────────
FACEBOOK_PAGE_ACCESS_TOKEN=

# ── Google Sheets (opcional) ──────────────────────────────
# 1. Google Cloud → Sheets API + Drive API habilitadas
# 2. Crear service account → descargar JSON
# 3. Crear hoja en Sheets → compartir con el email de service account
# 4. Copiar el ID de la hoja (entre /d/ y /edit en la URL)
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@xxx.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── CEO / Agencia ─────────────────────────────────────────
CEO_WHATSAPP_NUMBER=5491112345678
CALCOM_LINK=https://cal.com/tu-usuario/reunion-alm
AGENCY_NAME=Arab Lion Marketing
BOT_NAME=Leo

# ── Puerto del servidor ───────────────────────────────────
PORT=8000
